import React, { useState } from 'react';
import { Layout, Menu, Button, Avatar, Dropdown, Breadcrumb } from 'antd';
import { 
  MenuFoldOutlined, 
  MenuUnfoldOutlined, 
  DashboardOutlined,
  UserOutlined,
  TeamOutlined,
  DeploymentUnitOutlined,
  SettingOutlined,
  LogoutOutlined,
  BellOutlined,
  QuestionCircleOutlined
} from '@ant-design/icons';
import { useNavigate, useLocation } from 'react-router-dom';
import { useAuth } from '../../contexts/AuthContext';

const { Header, Sider, Content } = Layout;

const AppLayout: React.FC<{ children: React.ReactNode }> = ({ children }) => {
  const [collapsed, setCollapsed] = useState(false);
  const navigate = useNavigate();
  const location = useLocation();
  const { user, logout } = useAuth();

  // 菜单项配置
  const menuItems = [
    {
      key: '/dashboard',
      icon: <DashboardOutlined />,
      label: '仪表板',
    },
    {
      key: '/users',
    {
      key: '/roles',
        { key: '/units', icon: <DeploymentUnitOutlined />, label: '作战单位管理' },
      icon: <SafetyOutlined />,
      label: '角色管理',
    },
      icon: <TeamOutlined />,
      label: '用户管理',
    },
    {
      key: '/units',
      icon: <DeploymentUnitOutlined />,
      label: '作战单位',
      children: [
        { key: '/units/list', label: '单位列表' },
        { key: '/units/deploy', label: '单位部署' },
        { key: '/units/monitor', label: '单位监控' },
      ],
    },
    {
      key: '/missions',
      icon: <DeploymentUnitOutlined />,
      label: '任务管理',
      children: [
        { key: '/missions/list', label: '任务列表' },
        { key: '/missions/create', label: '创建任务' },
        { key: '/missions/assign', label: '任务分配' },
      ],
    },
    {
      key: '/reports',
      icon: <DashboardOutlined />,
      label: '报表统计',
      children: [
        { key: '/reports/combat', label: '作战报表' },
        { key: '/reports/system', label: '系统报表' },
        { key: '/reports/export', label: '报表导出' },
      ],
    },
    {
      key: '/system',
      icon: <SettingOutlined />,
      label: '系统设置',
      children: [
        { key: '/system/roles', label: '角色管理' },
        { key: '/system/permissions', label: '权限管理' },
        { key: '/system/logs', label: '系统日志' },
        { key: '/system/config', label: '系统配置' },
      ],
    },
  ];

  // 用户下拉菜单
  const userMenuItems = [
    {
      key: 'profile',
      icon: <UserOutlined />,
      label: '个人资料',
    },
    {
      key: 'settings',
      icon: <SettingOutlined />,
      label: '账户设置',
    },
    {
      type: 'divider',
    },
    {
      key: 'logout',
      icon: <LogoutOutlined />,
      label: '退出登录',
      danger: true,
    },
  ];

  // 处理菜单点击
  const handleMenuClick = ({ key }: { key: string }) => {
    if (key === 'logout') {
      logout();
      navigate('/login');
    } else if (key === 'profile') {
      navigate('/profile');
    } else if (key === 'settings') {
      navigate('/settings');
    } else {
      navigate(key);
    }
  };

  // 处理侧边栏菜单点击
  const handleSidebarClick = ({ key }: { key: string }) => {
    navigate(key);
  };

  // 获取当前选中的菜单项
  const getSelectedKeys = () => {
    const path = location.pathname;
    const selectedKeys: string[] = [path];
    
    // 如果当前路径是子菜单项，也需要选中父菜单
    menuItems.forEach(item => {
      if (item.children) {
        item.children.forEach(child => {
          if (child.key === path) {
            selectedKeys.push(item.key);
          }
        });
      }
    });
    
    return selectedKeys;
  };

  // 获取打开的子菜单
  const getOpenKeys = () => {
    const path = location.pathname;
    const openKeys: string[] = [];
    
    menuItems.forEach(item => {
      if (item.children) {
        item.children.forEach(child => {
          if (child.key === path) {
            openKeys.push(item.key);
          }
        });
      }
    });
    
    return openKeys;
  };

  return (
    <Layout className="min-h-screen">
      <Sider 
        trigger={null} 
        collapsible 
        collapsed={collapsed}
        width={250}
        className="shadow-lg"
      >
        <div className="h-16 flex items-center justify-center bg-blue-800">
          {collapsed ? (
            <div className="text-white text-xl font-bold">CIS</div>
          ) : (
            <div className="text-white text-xl font-bold">作战指挥系统</div>
          )}
        </div>
        
        <Menu
          theme="dark"
          mode="inline"
          selectedKeys={getSelectedKeys()}
          defaultOpenKeys={getOpenKeys()}
          items={menuItems}
          onClick={handleSidebarClick}
          className="pt-4"
        />
      </Sider>
      
      <Layout>
        <Header className="bg-white px-4 flex items-center justify-between shadow-sm">
          <div className="flex items-center">
            <Button
              type="text"
              icon={collapsed ? <MenuUnfoldOutlined /> : <MenuFoldOutlined />}
              onClick={() => setCollapsed(!collapsed)}
              className="text-lg"
            />
            
            <Breadcrumb className="ml-4">
              <Breadcrumb.Item>首页</Breadcrumb.Item>
              <Breadcrumb.Item>仪表板</Breadcrumb.Item>
            </Breadcrumb>
          </div>
          
          <div className="flex items-center space-x-4">
            <Button 
              type="text" 
              icon={<BellOutlined />} 
              shape="circle"
            />
            <Button 
              type="text" 
              icon={<QuestionCircleOutlined />} 
              shape="circle"
            />
            
            <Dropdown menu={{ items: userMenuItems, onClick: handleMenuClick }}>
              <div className="flex items-center cursor-pointer hover:bg-gray-100 px-3 py-1 rounded">
                <Avatar 
                  icon={<UserOutlined />} 
                  className="mr-2"
                  style={{ backgroundColor: '#1890ff' }}
                />
                {!collapsed && (
                  <div>
                    <div className="font-medium">{user?.fullName || user?.username}</div>
                    <div className="text-xs text-gray-500">{user?.rank || '指挥员'}</div>
                  </div>
                )}
              </div>
            </Dropdown>
          </div>
        </Header>
        
        <Content className="m-4 p-6 bg-white rounded-lg shadow-sm">
          {children}
        </Content>
      </Layout>
    </Layout>
  );
};

export default AppLayout;
